{
  "Name": "BTX_AdvancedMechLab",
  "Enabled": true,
  "Version": "0.1",
  
  "Description": "Allows for armor and engine cooling customization in the MechLab.",
  "Author": "Kierk",
  "Website": "https://github.com/AkiraBrahe/BTX_AdvancedMechLab",

  "ConflictsWith": [ "ArmorRepair" ],
  "DependsOn": [ "BTX_ExpansionPack", "LootMagnet" ],

  "DLL": "BTX_AdvancedMechLab.dll",

  "Settings": {
    "ArmorRepair": {
      "EnableStructureRepair": true,
      "EnableTonnageRepairScaling": true,
      "EnableAutoRepairPrompt": true,
      "AutoRepairMechsWithDestroyedComponents": true,
      "ClanTechRepairCostMultiplier ": 1.5
    },
    "ArmorSalvage": {
      "EnableArmorStackLimit": true,
      "MaxTonsPerStack": 10
    }
  },

  "Manifest": [
    { "Type": "HeatSinkDef", "Path": "heatsinks" },
    { "Type": "UpgradeDef", "Path": "upgrades", "AddToDB": true }
  ]
}